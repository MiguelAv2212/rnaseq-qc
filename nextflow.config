/*
 * Pipeline parameters
 */
params {
    input                     = 'undefined'
    genome                    = 'undefined'
    outdir                    = 'undefined'
    min_retained_percentage   = 'undefined'
    min_mapped_percentage     = 'undefined'
}

/*
 * Default process configuration
 */
process {
    executor  = 'local'
    cpus      = 1
    memory    = 2.GB
    time      = 1.h

    errorStrategy = 'terminate'
    maxRetries    = 1

    shell = ['/bin/bash', '-euo', 'pipefail']

    withName: 'preprocessReads' {
        cpus   = 2
        memory = 3.GB
    }
    withName: 'indexReference' {
        cpus   = 2
        memory = 4.GB
    }
    withName: 'align' {
        cpus   = 2
        memory = 4.GB
    }
}

/*
 * Execution report, do not change this part
 */
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report_min-retained-${params.min_retained_percentage}.html"
    overwrite = true
}

/*
 * Execution timeline, do not change this part
 */
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

/*
 * Per-task execution trace, do not change this part
 */
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.tsv"
    overwrite = true
    fields = [
        'task_id', 'hash', 'process', 'tag', 'status', 'exit',
        'container', 'cpus', 'memory', 'attempt', 'submit', 'start',
        'complete', 'duration', 'realtime', '%cpu', '%mem',
        'peak_rss', 'read_bytes', 'write_bytes', 'workdir'
    ].join(',')
}

/*
 * Workflow DAG, do not change this part
 */
dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/workflow_dag.html"
    overwrite = true
    direction = 'LR'
}

/*
 * Execution profiles
 */
profiles {
    standard {
        process.executor = 'local'
    }

    docker {
        docker {
            enabled    = true
            runOptions = '--user $(id -u):$(id -g)'
        }
        process.executor = 'local'
    }

    test {
        params.input                   = "${projectDir}/samplesheet.csv"
        params.genome                  = "${projectDir}/data/genome.fa"
        params.outdir                  = 'results'
        params.min_retained_percentage = 90
        params.min_mapped_percentage   = 70
    }
}

/*
 * General Nextflow settings
 */
workDir = 'work'
cleanup = false

manifest {
    name            = 'bioit-rnaseq-qc'
    description     = 'Dockerized RNA-seq intake quality-control workflow'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.10.0'
}
